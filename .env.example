# Her app kendi ihtiyacına göre override edebilir.
# Gerçek sırlar asla commit'lenmez — .env dosyasını .gitignore engeller.

# ─── Ortam ───
NODE_ENV=development
LOG_LEVEL=info

# ─── API ───
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# On-premise tek-kiracı kurulumda tek Odoo DB'si (default: hashtap)
ODOO_BASE_URL=http://localhost:8069
ODOO_DB=hashtap

# ─── Postgres ───
DATABASE_URL=postgres://hashtap:hashtap@localhost:5432/hashtap

# ─── Redis / Queue ───
REDIS_URL=redis://localhost:6379

# ─── JWT / Session ───
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ─── iyzico (restoran subMerchant — kurulum sırasında doldurulur) ───
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── e-Arşiv (restoran sağlayıcısı) ───
EFATURA_PROVIDER=foriba
EFATURA_USERNAME=
EFATURA_PASSWORD=

# ─── Customer PWA ───
VITE_API_BASE_URL=http://localhost:4000
VITE_PUBLIC_URL=http://localhost:5173

# ─── Restaurant Dashboard ───
VITE_DASHBOARD_API_URL=http://localhost:4000

# ─── Print Bridge (yerel cihazda) ───
PRINT_BRIDGE_DEVICE_ID=
PRINT_BRIDGE_API_URL=ws://localhost:4000/bridge
