# HashTap CEO AI Bot — env example
# Kopyala: .env (gitignored)

# ─── LLM Provider ────────────────────────────────────────────────────
# ollama (default) | anthropic | openai | bedrock
PROVIDER=ollama

# Ollama (lokal model)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_KEEP_ALIVE=10m

# Anthropic (opsiyonel)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (opsiyonel)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# AWS Bedrock (opsiyonel)
AWS_REGION=eu-central-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-6

# ─── Odoo (HashTap backend) ──────────────────────────────────────────
ODOO_URL=http://host.docker.internal:8069
ODOO_DB=hashtap
ODOO_USER=ceo@hashtap.local
ODOO_PASSWORD=ceo-bot-password

# CEO bot user'ın partner ID'si (Odoo modülü kurulduktan sonra
# /web → res.users → CEO → partner → ID kopyala)
ODOO_CEO_PARTNER_ID=0

# ─── Discuss (bus.bus WebSocket) ─────────────────────────────────────
DISCUSS_BUS_URL=ws://host.docker.internal:8072/websocket
# Polling fallback aralığı (saniye); 0 = polling tamamen kapalı
DISCUSS_POLL_INTERVAL_SECONDS=10

# ─── Telegram (opsiyonel kanal) ──────────────────────────────────────
# https://t.me/BotFather → /newbot → token al
TELEGRAM_BOT_TOKEN=
# Sadece bu chat ID(ler)den gelen mesajlar işlenir (CSV)
TELEGRAM_ALLOWED_CHATS=

# ─── Agent davranışı ────────────────────────────────────────────────
# Kullanıcı başı tutulan son mesaj sayısı (sliding window)
AGENT_MAX_HISTORY=20
# Üstü olunca summarize edilir
AGENT_SUMMARIZE_AFTER=50

# Sidecar HTTP portu
HOST=0.0.0.0
PORT=4200

# Audit log dosyası (her tool çağrısı buraya jsonl)
AUDIT_LOG_PATH=./sessions/audit.jsonl

# Session dizini
SESSION_DIR=./sessions
