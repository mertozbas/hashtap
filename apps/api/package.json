{
  "name": "@hashtap/api",
  "version": "0.1.0",
  "private": true,
  "description": "HashTap backend — sipariş, ödeme, POS adapter orkestrasyonu",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/websocket": "^10.0.1",
    "@hashtap/efatura": "*",
    "@hashtap/payment": "*",
    "@hashtap/pos-adapters": "*",
    "@hashtap/shared": "*",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "pg-boss": "^10.1.0",
    "pino": "^9.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
