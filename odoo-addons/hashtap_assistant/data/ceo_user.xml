<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- CEO partner — Discuss avatarı + bot olarak görünüm -->
    <record id="ceo_partner" model="res.partner">
        <field name="name">CEO</field>
        <field name="email">ceo@hashtap.local</field>
        <field name="company_type">person</field>
    </record>

    <!-- CEO user — apps/ai-bot bunun login + password'ünü kullanır.
         Şifre kurulumdan sonra Ayarlar > Kullanıcılar üstünden değiştirilir.
    -->
    <record id="ceo_user" model="res.users">
        <field name="name">CEO</field>
        <field name="login">ceo@hashtap.local</field>
        <field name="password">ceo-bot-password</field>
        <field name="partner_id" ref="ceo_partner"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('base.group_user'),
            ref('base.group_system')
        ])]"/>
        <field name="signature"><![CDATA[<p><b>— CEO</b><br/><i>HashTap AI Asistanı</i></p>]]></field>
    </record>

</odoo>
