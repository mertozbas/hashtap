<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- /web/login sayfası — "Powered by Odoo" yazısını gizle, branding HashTap. -->
    <template id="hashtap_login_layout" name="HashTap Login" inherit_id="web.login_layout">
        <xpath expr="//div[hasclass('o_login_footer')]" position="replace">
            <div class="o_login_footer text-center">
                <small>© HashTap</small>
            </div>
        </xpath>
    </template>

</odoo>
